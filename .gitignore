# ==========================================
# 1. Thư mục Build và Biên dịch (Meson/Ninja)
# ==========================================
build/
build_static/
subprojects/
/.mesonpy/

# ==========================================
# 2. File cấu hình cho bộ phân tích code (LSP / Neovim)
# ==========================================
compile_commands.json
.clangd/
.ccls-cache/

# ==========================================
# 3. File dữ liệu kiểm thử (PCAP) và Log
# ==========================================
# Giữ lại thư mục pcap nhưng không đẩy các file .pcap nặng lên Git
pcap/*.pcap
!pcap/.gitkeep
tests/generated/*
!tests/generated/.gitignore
tests/__pycache__/

*.log
*.out
*.pid
core
core.*

# ==========================================
# 4. Các file nhị phân thực thi cuối cùng (Nếu có export ra ngoài)
# ==========================================
flowcore
helloworld
src/main

# ==========================================
# 5. File tạm của Hệ điều hành và Trình soạn thảo
# ==========================================
.swp
*~
.DS_Store
.idea/
.vscode/

# ==========================================
# 6. Markdown files
# ==========================================
*.md
**/*.md
!README.md
!**/README.md
!docs/current_architecture.md
!docs/current_optimization.md
!docs/defense_guide_current.md
!docs/test_coverage_current.md
